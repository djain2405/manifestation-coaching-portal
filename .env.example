# Supabase (required for full platform features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site URL for password reset emails
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# First admin: this email gets admin role on signup
ADMIN_EMAIL=

# Loom workspace API (admin video picker only — server-side)
LOOM_API_KEY=

# Legacy fallback when Supabase is not configured
PORTAL_PASSWORD=change-me-before-deploy
